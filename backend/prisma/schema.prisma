// Prisma schema de VasoChain AI

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoEntrega {
  PENDIENTE
  VALIDADA
  RECHAZADA
}

enum OrigenEntrega {
  simulado
  whatsapp_real
}

model Beneficiario {
  id           String   @id @default(uuid())
  nombre       String
  dni          String   @unique
  qrCode       String   @unique @map("qr_code")
  clubMadres   String   @map("club_madres")
  sector       String
  creadoEn     DateTime @default(now()) @map("creado_en")

  entregas Entrega[]

  @@map("beneficiarios")
}

model Entrega {
  id               String        @id @default(uuid())
  beneficiarioId   String        @map("beneficiario_id")
  fecha            DateTime      @default(now())
  fotoUrl          String?       @map("foto_url")
  resultadoIa      Json?         @map("resultado_ia")
  hashBlockchain   String?       @map("hash_blockchain")
  txHash           String?       @map("tx_hash")
  estado           EstadoEntrega @default(PENDIENTE)
  origen           OrigenEntrega @default(simulado)

  beneficiario Beneficiario @relation(fields: [beneficiarioId], references: [id])
  alertas      Alerta[]
  controlRuns  ControlRun[]

  @@map("entregas")
}

model Alerta {
  id        String   @id @default(uuid())
  entregaId String   @map("entrega_id")
  tipo      String
  mensaje   String
  fecha     DateTime @default(now())

  entrega Entrega @relation(fields: [entregaId], references: [id])

  @@map("alertas")
}

enum ControlStatus {
  BORRADOR
  VALIDADO
  APROBADO
  EN_PRUEBAS
  PRODUCCION
  DESCARTADO
}

enum TestStatus {
  PENDIENTE
  EN_EJECUCION
  APROBADO
  FALLIDO
}

model ControlCategory {
  id          String    @id @default(uuid())
  nombre      String    @unique
  descripcion String?
  orden       Int       @default(0)
  creadoEn    DateTime  @default(now()) @map("creado_en")

  controls Control[]

  @@map("categorias_controles")
}

model Control {
  id                 String         @id @default(uuid())
  identificador      String         @unique
  descripcion        String
  categoriaId        String         @map("categoria_id")
  dependencias       Json?
  requerimientosAcceso Json?        @map("requerimientos_acceso")
  objetivosAlineados Json?         @map("objetivos_alineados")
  estado             ControlStatus  @default(BORRADOR)
  esFrecuente        Boolean        @default(false) @map("es_frecuente")
  orden              Int            @default(0)
  creadoEn           DateTime       @default(now()) @map("creado_en")
  actualizadoEn      DateTime       @updatedAt @map("actualizado_en")

  categoria ControlCategory @relation(fields: [categoriaId], references: [id])
  testResults TestResult[]
  documentation Documentation[]

  @@map("controles")
}

model DiscardedControl {
  id               String   @id @default(uuid())
  controlId        String   @unique @map("control_id")
  identificador    String
  descripcion      String
  categoriaId      String   @map("categoria_id")
  motivoEliminacion String   @map("motivo_eliminacion")
  criteriosAplicados Json?  @map("criterios_aplicados")
  responsable      String
  fechaEliminacion DateTime @default(now()) @map("fecha_eliminacion")

  @@map("controles_descartados")
}

model TestResult {
  id               String      @id @default(uuid())
  controlId        String      @map("control_id")
  tipoPrueba       String      @map("tipo_prueba")
  estado           TestStatus  @default(PENDIENTE)
  resultado        Json?
  mensaje          String?
  ejecutadoPor     String?     @map("ejecutado_por")
  fechaEjecucion   DateTime?   @map("fecha_ejecucion")
  creadoEn         DateTime    @default(now()) @map("creado_en")

  control Control @relation(fields: [controlId], references: [id])

  @@map("resultados_pruebas")
}

model Documentation {
  id               String   @id @default(uuid())
  controlId        String?  @map("control_id")
  tipoDocumento    String   @map("tipo_documento")
  titulo           String
  contenido        String
  version          String   @default("1.0")
  creadoPor        String?  @map("creado_por")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  control Control? @relation(fields: [controlId], references: [id])

  @@map("documentacion")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  nombre           String
  rol              String   @default("admin")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// Nuevos modelos para el sistema de "arnés" Lean Startup
enum NivelControl {
  NIVEL_1_ENTRADA
  NIVEL_2_FOTO
  NIVEL_3_DATOS
  NIVEL_4_BLOCKCHAIN
  NIVEL_5_SUPERVISION
}

enum CriticidadControl {
  CRITICA
  MEDIA
  BAJA
}

model HarnessControl {
  id               Int              @id @unique
  identificador    String
  descripcion      String
  nivel            NivelControl
  criticidad       CriticidadControl
  estado           Boolean          @default(true) // true = activo
  orden            Int
  creadoEn         DateTime         @default(now()) @map("creado_en")
  actualizadoEn    DateTime         @updatedAt @map("actualizado_en")

  controlRuns      ControlRun[]
  controlMetric    ControlMetric?

  @@map("harness_controles")
}

model ControlRun {
  id               String           @id @default(uuid())
  controlId        Int              @map("control_id")
  entregaId        String           @map("entrega_id")
  resultado        Boolean          // true = pasó, false = falló
  tiempoMs         Int              @map("tiempo_ms")
  alertasCount     Int              @map("alertas_count")
  ejecutadoEn      DateTime         @default(now()) @map("ejecutado_en")

  control          HarnessControl   @relation(fields: [controlId], references: [id], onDelete: Cascade)
  entrega          Entrega          @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@map("control_runs")
}

model ControlMetric {
  id               String           @id @default(uuid())
  controlId        Int              @unique @map("control_id")
  falsosPositivos  Int              @default(0) @map("falsos_positivos")
  verdaderosPositivos Int           @default(0) @map("verdaderos_positivos")
  falsosNegativos  Int              @default(0) @map("falsos_negativos")
  verdaderosNegativos Int           @default(0) @map("verdaderos_negativos")
  fraudePrevenido  Boolean          @default(false) @map("fraude_prevenido")
  tiempoAgregadoMs Int              @default(0) @map("tiempo_agregado_ms")
  ejecucionesCount Int              @default(0) @map("ejecuciones_count")
  valorRatio       Float            @default(0) @map("valor_ratio")
  actualizadoEn    DateTime         @updatedAt @map("actualizado_en")

  control          HarnessControl   @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("control_metrics")
}
