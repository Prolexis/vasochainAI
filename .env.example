# =========================================================
# VasoChain AI — Variables de entorno
# Copia este archivo como ".env" y completa los valores reales.
# =========================================================

# --- Base de datos (PostgreSQL) ---
POSTGRES_USER=vasochain
POSTGRES_PASSWORD=vasochain
POSTGRES_DB=vasochain

# --- IA de validación de imágenes ---
# El sistema soporta dos proveedores: Anthropic Claude y OpenAI GPT-4o.
# Configura SOLO la API key del proveedor que quieras usar.
# Si configuras ambas, usa AI_PROVIDER para elegir cuál (openai | anthropic).
# Sin AI_PROVIDER, el sistema auto-detecta según cuál key esté configurada.

# Proveedor de IA (opcional: "openai" o "anthropic")
# AI_PROVIDER=openai

# OpenAI (GPT-4o con visión)
# Obtenla en https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# Anthropic (Claude con visión)
# Obtenla en https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aqui

# --- WhatsApp real vía Twilio Sandbox (Plan B, opcional) ---
# Sin estas credenciales, el Plan A funciona igual; solo el webhook
# real de WhatsApp quedará deshabilitado.
# Consíguelas en https://console.twilio.com/ (sección WhatsApp Sandbox)
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Blockchain (nodo Hardhat local) ---
# Estos valores ya tienen defaults funcionales para desarrollo local;
# normalmente no necesitas tocarlos.
BLOCKCHAIN_RPC_URL=http://hardhat-node:8545
CONTRACT_SHARED_PATH=/shared/contract.json
# Clave privada de la cuenta #0 que Hardhat node genera por defecto en
# su red local de desarrollo (NO usar en producción real).
BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Frontend ---
# URL pública donde el navegador del usuario alcanza al backend.
VITE_API_URL=http://localhost:3000
